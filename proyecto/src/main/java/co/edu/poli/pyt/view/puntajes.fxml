<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="co.edu.poli.pyt.controller.PuntajesController"
      alignment="CENTER"
      spacing="16"
      stylesheets="@style.css"
      styleClass="scores-root">

    <Label text="Puntajes" styleClass="instructions-title"/>

    <TableView fx:id="puntajesTable" prefWidth="700" prefHeight="340" styleClass="scores-table">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
            <TableColumn fx:id="nombreColumn" text="Nombre del jugador" prefWidth="300"/>
            <TableColumn fx:id="puntajeColumn" text="Puntaje total" prefWidth="160"/>
            <TableColumn fx:id="ganadasColumn" text="Partidas ganadas" prefWidth="160"/>
        </columns>
    </TableView>

    <Label fx:id="mensajeLabel" styleClass="login-message"/>

    <Button text="CERRAR"
            styleClass="btn-instructions"
            onAction="#cerrar"/>

</VBox>
