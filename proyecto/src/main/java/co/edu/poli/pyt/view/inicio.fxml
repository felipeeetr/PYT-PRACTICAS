<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="co.edu.poli.pyt.controller.InicioController"
      alignment="CENTER"
      spacing="20"
      stylesheets="@style.css"
      styleClass="root">

    <Label text="Ooodle game" styleClass="title"/>

    <Button text="INSTRUCCIONES"
            styleClass="btn-instructions"
            onAction="#mostrarInstrucciones"/>

    <Button text="INICIAR PARTIDA"
            styleClass="btn-start"
            onAction="#iniciarJuego"/>

</VBox>
