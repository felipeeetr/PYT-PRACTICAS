<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="co.edu.poli.pyt.controller.InicioController"
      alignment="CENTER"
      spacing="20"
      stylesheets="@style.css"
      styleClass="root">

    <Label text="Ooodle game" styleClass="title"/>

    <VBox alignment="CENTER" spacing="10" styleClass="login-panel">
        <Label text="Jugador" styleClass="subtitle"/>
        <TextField fx:id="nombreField"
                   promptText="Nombre de usuario"
                   maxWidth="260"
                   styleClass="login-field"/>

        <HBox alignment="CENTER" spacing="12">
            <Button text="INICIAR SESION"
                    styleClass="btn-start"
                    onAction="#iniciarConUsuario"/>

            <Button text="INVITADO"
                    styleClass="btn-range"
                    onAction="#iniciarComoInvitado"/>
        </HBox>

        <Label fx:id="mensajeLabel" styleClass="login-message"/>
    </VBox>

    <Button text="INSTRUCCIONES"
            styleClass="btn-instructions"
            onAction="#mostrarInstrucciones"/>

    <Button text="VER PUNTAJES"
            styleClass="btn-start"
            onAction="#verPuntajes"/>

</VBox>
